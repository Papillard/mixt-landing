---
const conditions = [
  {
    name: 'Rosacée',
    description: 'Rougeurs, flush, couperose.',
    img: '/images/rosacea.webp',
  },
  {
    name: 'Hyperpigmentation',
    description: 'Mélasma, taches solaires, PIH.',
    img: '/images/hyperpigmentation.webp',
  },
  {
    name: 'Acné adulte',
    description: 'Hormonale, inflammatoire, kystique.',
    img: '/images/acne.webp',
  },
  {
    name: 'Eczéma',
    description: 'Atopique, de contact, séborrhéique.',
    img: '/images/eczema.webp',
  },
];
---

<section id="conditions" class="px-10 py-24 md:py-32 bg-base">
  <div class="max-w-[1100px] mx-auto">
    <div class="flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.14em] text-ink-2 mb-5">
      <span class="inline-block h-px w-10 bg-ink-2/60"></span>
      Conditions prises en charge
    </div>
    <h2 class="font-serif text-[40px] md:text-[52px] font-normal leading-[1.1] tracking-[-0.03em] max-w-[620px] mb-14" style="font-variation-settings: 'opsz' 144;">
      Pour les peaux qui <span class="italic-serif">n'ont pas de réponse simple.</span>
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {conditions.map((c) => (
        <article class="group relative overflow-hidden rounded-2xl bg-cream">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={c.img}
              alt={c.name}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
            />
          </div>
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/75 via-black/30 to-transparent p-5 pt-16">
            <h3 class="text-white font-serif text-2xl font-medium mb-0.5">{c.name}</h3>
            <p class="text-white/80 text-sm">{c.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
