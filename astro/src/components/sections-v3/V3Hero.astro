---
import Button from '../Button.astro';
import HeroReveal from '../motion/HeroReveal.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';
import HeroMasiChart from '../motion/HeroMasiChart.tsx';
---

<section class="relative px-6 md:px-10 pt-[calc(56px+80px)] pb-20 md:pb-28 bg-base">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-20 items-center">
    <div>
      <HeroReveal
        client:load
        eyebrow="Programme dermato · 12 semaines"
        eyebrowMono={true}
        title="Votre peau mérite un traitement"
        highlight="sur-mesure."
        subtitle="Un dermatologue comprend votre peau et prescrit un traitement personnalisé. Préparé par une pharmacie partenaire. Ajusté mois après mois."
      >
        <div class="flex flex-wrap gap-3">
          <Button href="/premieres-patientes" variant="ember-pill">Obtenir ma formule →</Button>
          <Button href="#approche" variant="ghost">Voir comment ça marche</Button>
        </div>
      </HeroReveal>

      <FadeInSection client:load delay={0.55} y={14} className="mt-12 pt-6 border-t border-ink/10">
        <div class="grid grid-cols-3 gap-5 items-start">
          <div class="pr-4 border-r border-ink/10">
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight mb-1.5 tracking-[-0.01em]">Sur ordonnance</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">100 % personnalisé</div>
          </div>
          <div class="pr-4 border-r border-ink/10">
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight mb-1.5 tracking-[-0.01em]">12 semaines</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">Premiers résultats</div>
          </div>
          <div>
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight mb-1.5 tracking-[-0.01em]">Suivi 1:1</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">Par un dermatologue</div>
          </div>
        </div>
      </FadeInSection>
    </div>

    <FadeInSection client:load delay={0.25} y={24}>
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-blush/30 shadow-[0_20px_60px_-20px_rgba(54,24,34,0.35)]">
        <img
          src="/images/hero-new.jpg"
          alt="Portrait d'une patiente Mixt"
          class="absolute inset-0 h-full w-full object-cover object-[center_30%]"
          fetchpriority="high"
        />
        {/* Gradient sombre ultra-léger bottom-left pour lisibilité du graph sans dénaturer la photo */}
        <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 65% 60% at 0% 100%, rgba(26,18,16,0.22) 0%, rgba(26,18,16,0.08) 35%, transparent 65%);"></div>

        {/* Chip marron top-left */}
        <div class="absolute left-5 top-5 z-[5] rounded-[6px] bg-deep/95 backdrop-blur px-3 py-1.5 text-[10px] font-semibold tracking-[0.18em] uppercase text-white">
          Mélasma
        </div>

        {/* Chip résultat bottom-right */}
        <div class="absolute right-5 bottom-5 z-[5] rounded-[6px] bg-deep/95 backdrop-blur px-3.5 py-2 text-[13px] font-semibold text-white font-mono tracking-[0.04em]">
          S.8 · −16 %
        </div>

        {/* Graph MASI overlay */}
        <HeroMasiChart client:load />
      </div>
    </FadeInSection>
  </div>
</section>
