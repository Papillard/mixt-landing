---
interface Props {
  href?: string;
  variant?: 'dark' | 'white' | 'ghost' | 'ghost-light';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'dark',
  size = 'lg',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center gap-2 font-semibold no-underline cursor-pointer rounded-[6px] transition-all duration-200 border';

const sizeMap = {
  sm: 'px-4 py-2 text-[13px]',
  md: 'px-5 py-3 text-sm',
  lg: 'px-[30px] py-3.5 text-[15px]',
};

const variantMap = {
  dark: 'bg-deep text-white border-deep hover:bg-[#2B1018]',
  white: 'bg-white text-ink border-white hover:bg-[#f5f5f5]',
  ghost: 'bg-transparent text-ink border-black/[0.12] hover:border-warm',
  'ghost-light': 'bg-transparent text-white border-white/20 hover:border-white/50',
};

const Tag = href ? 'a' : 'button';
const classes = `${base} ${sizeMap[size]} ${variantMap[variant]} ${className}`;
---

<Tag class={classes} href={href} {...rest}>
  <slot />
</Tag>
