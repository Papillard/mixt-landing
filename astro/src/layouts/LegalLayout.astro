---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav ctaLabel="Faire mon bilan" ctaHref="/premieres-patientes" />

  <section class="s-legal">
    <div class="inner">
      <slot />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  /* Tokens v3 — Geist sans-serif pour titres, Newsreader italic pour les em, ember accent */
  .s-legal { padding: calc(56px + 80px) 40px 120px; background: var(--color-base); }
  .s-legal .inner { max-width: 780px; margin: 0 auto; }
  .s-legal h1 {
    font-size: 44px;
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 8px;
    color: var(--color-ink);
  }
  .s-legal h1 em {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.08em;
  }
  .s-legal .legal-date {
    font-family: 'DM Mono', ui-monospace, monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ember-deep);
    margin-bottom: 56px;
  }
  .s-legal h2 {
    font-size: 24px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin: 56px 0 18px;
    color: var(--color-ink);
  }
  .s-legal h3 {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.4;
    margin: 36px 0 12px;
    color: var(--color-ink);
  }
  .s-legal p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-2);
    margin-bottom: 14px;
  }
  .s-legal strong { color: var(--color-ink); font-weight: 600; }
  .s-legal a {
    color: var(--color-ember-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
  .s-legal a:hover { color: var(--color-ember); }
  .s-legal ul { list-style: none; padding: 0; margin: 0 0 14px; }
  .s-legal ul li {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink-2);
    padding-left: 22px;
    position: relative;
    margin-bottom: 8px;
  }
  .s-legal ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 12px;
    height: 1px;
    background: var(--color-ember);
  }
  .s-legal .alert-box {
    background: var(--color-cream);
    border-left: 3px solid var(--color-ember);
    padding: 20px 24px;
    border-radius: 0 8px 8px 0;
    margin: 24px 0;
  }
  .s-legal .alert-box p { margin-bottom: 0; font-weight: 500; color: var(--color-ink); }
  .s-legal hr {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    margin: 56px 0;
  }
  .s-legal .legal-block {
    background: var(--color-cream);
    border-radius: 8px;
    padding: 24px 28px;
    margin: 24px 0;
  }
  .s-legal .legal-block p { margin-bottom: 8px; }
  .s-legal .legal-block p:last-child { margin-bottom: 0; }
  @media (max-width: 768px) {
    .s-legal { padding: calc(56px + 40px) 20px 72px; }
    .s-legal h1 { font-size: 32px; }
    .s-legal h2 { font-size: 20px; margin-top: 40px; }
  }
</style>
