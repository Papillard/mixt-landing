---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav ctaLabel="Faire mon bilan" ctaHref="/premieres-patientes" />

  <section class="s-legal">
    <div class="inner">
      <slot />
    </div>
  </section>

  <Footer />
</BaseLayout>

<style is:global>
  .s-legal { padding: calc(56px + 60px) 40px 100px; }
  .s-legal .inner { max-width: 780px; margin: 0 auto; }
  .s-legal h1 { font-family: 'Fraunces', serif; font-size: 36px; font-weight: 400; line-height: 1.2; letter-spacing: -0.03em; margin-bottom: 8px; color: var(--text); font-variation-settings: 'opsz' 144; }
  .s-legal h1 em { font-family: 'Newsreader', serif; font-style: italic; font-weight: 400; font-size: 1.08em; }
  .s-legal .legal-date { font-size: 14px; color: var(--text-3); margin-bottom: 48px; }
  .s-legal h2 { font-size: 24px; font-weight: 600; line-height: 1.3; letter-spacing: -0.02em; margin: 48px 0 16px; color: var(--text); }
  .s-legal h3 { font-size: 18px; font-weight: 600; line-height: 1.4; margin: 32px 0 12px; color: var(--text); }
  .s-legal p { font-size: 15px; line-height: 1.7; color: var(--text-2); margin-bottom: 14px; }
  .s-legal strong { color: var(--text); font-weight: 600; }
  .s-legal ul { list-style: none; padding: 0; margin: 0 0 14px; }
  .s-legal ul li { font-size: 15px; line-height: 1.7; color: var(--text-2); padding-left: 20px; position: relative; margin-bottom: 8px; }
  .s-legal ul li::before { content: '—'; position: absolute; left: 0; color: var(--accent); font-weight: 600; }
  .s-legal .alert-box { background: var(--cream); border-left: 3px solid var(--accent); padding: 20px 24px; border-radius: 0 6px 6px 0; margin: 20px 0; }
  .s-legal .alert-box p { margin-bottom: 0; font-weight: 500; color: var(--text); }
  .s-legal hr { border: none; border-top: 1px solid var(--border); margin: 48px 0; }
  .s-legal .legal-block { background: var(--cream); border-radius: 6px; padding: 24px 28px; margin: 20px 0; }
  .s-legal .legal-block p { margin-bottom: 8px; }
  .s-legal .legal-block p:last-child { margin-bottom: 0; }
  @media (max-width: 768px) {
    .s-legal { padding: calc(56px + 32px) 20px 60px; }
    .s-legal h1 { font-size: 28px; }
    .s-legal h2 { font-size: 20px; margin-top: 36px; }
  }
</style>
