---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import V3Hero from '../components/sections-v3/V3Hero.astro';
import V3Problem from '../components/sections-v3/V3Problem.astro';
import V3Pillars from '../components/sections-v3/V3Pillars.astro';
import V3Steps from '../components/sections-v3/V3Steps.astro';
import V3Respiration from '../components/sections-v3/V3Respiration.astro';
import V3Conditions from '../components/sections-v3/V3Conditions.astro';
import V3Science from '../components/sections-v3/V3Science.astro';
import V3Testimonials from '../components/sections-v3/V3Testimonials.astro';
import V3Team from '../components/sections-v3/V3Team.astro';
import V3Pricing from '../components/sections-v3/V3Pricing.astro';
import V3FaqCta from '../components/sections-v3/V3FaqCta.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://mixt.care/#organization',
      name: 'Mixt',
      url: 'https://mixt.care',
      logo: 'https://mixt.care/favicons/android-chrome-512x512.png',
      description:
        'Service médical français de dermatologie en ligne. Téléconsultation, formulation magistrale personnalisée préparée en pharmacie partenaire, et suivi dermatologique continu pour les conditions chroniques de la peau.',
      founder: [
        { '@id': 'https://mixt.care/#laetitia' },
        { '@id': 'https://mixt.care/#boris' },
        { '@id': 'https://mixt.care/#bethsabee' },
      ],
    },
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://mixt.care/#medicalbusiness',
      name: 'Mixt',
      url: 'https://mixt.care',
      image: 'https://mixt.care/images/og-image.png',
      medicalSpecialty: 'Dermatology',
      availableService: [
        {
          '@type': 'MedicalTherapy',
          name: 'Téléconsultation dermatologique',
          description:
            'Consultation vidéo ou téléphonique avec un médecin pour évaluer votre peau, poser un diagnostic et prescrire un protocole personnalisé.',
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Formulation magistrale personnalisée',
          description:
            "Préparation en pharmacie partenaire sur ordonnance médicale, avec principes actifs choisis et dosés pour votre cas.",
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Suivi dermatologique continu',
          description:
            "Abonnement de suivi médical : un dermatologue qui ajuste et renouvelle le traitement en continu, en appui d'un accompagnement humain non médical (experte Mixt) — photos et questions chaque semaine.",
        },
      ],
      areaServed: { '@type': 'Country', name: 'France' },
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#laetitia',
      name: 'Laetitia Payan',
      jobTitle: 'CEO & Co-fondatrice',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/laetitia-after.webp',
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#boris',
      name: 'Boris Paillard',
      jobTitle: 'CPO & Co-fondateur',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/boris.webp',
    },
    {
      '@type': 'Physician',
      '@id': 'https://mixt.care/#bethsabee',
      name: 'Dr Bethsabée Levy Garel',
      jobTitle: 'Dermatologue Fondatrice',
      medicalSpecialty: 'Dermatology',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/bethsabee.webp',
      alumniOf: 'Sorbonne Université',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://mixt.care/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: "Les 29 €/mois, c'est quoi exactement ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "C'est votre suivi médical continu — ce qui fait qu'un traitement marche vraiment dans la durée. Votre experte Mixt, chaque semaine : elle suit vos photos, répond à vos questions, vous accompagne dans votre routine au quotidien (rôle non médical, mais toujours présente). Un dermatologue qui ajuste et renouvelle en continu : en appui de votre experte, il valide et propose votre plan, dose les bons actifs, renouvelle et ajuste votre traitement au fil du temps, et intervient si besoin. Un accès dermatologue sous une semaine : fini les 3 à 6 mois d'attente. Le traitement, lui, n'est pas compris dans les 29 €/mois.",
          },
        },
        {
          '@type': 'Question',
          name: 'Le traitement est-il compris dans l\'abonnement ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Non. Les 29 €/mois couvrent votre suivi médical — l'accompagnement de votre experte Mixt et le dermatologue qui ajuste et renouvelle votre prise en charge. Le traitement est à part : si votre dermatologue prescrit une formule magistrale sur mesure, elle est préparée en pharmacie partenaire et coûte 30 à 60 € selon les actifs. Parce que c'est une vraie prescription médicale, elle est partiellement remboursée par la Sécurité sociale et votre mutuelle — là où la plupart des services en ligne vous laissent tout à votre charge. Vous savez exactement ce que vous payez, et à qui, dès le départ.",
          },
        },
        {
          '@type': 'Question',
          name: 'Qui ajuste et renouvelle mon traitement ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Votre dermatologue, et lui seul. Il intervient en async, en appui de votre experte Mixt : il valide et propose votre plan de traitement, choisit et dose les bons actifs, puis le renouvelle et l'ajuste au fil du temps selon l'évolution de votre peau. Votre experte Mixt fait le lien au quotidien : elle suit vos photos et vos ressentis, et fait remonter à votre dermatologue tout ce qui mérite son attention. C'est ce travail à deux — humain au quotidien, médical en continu — qui permet à votre traitement de rester juste dans la durée.",
          },
        },
        {
          '@type': 'Question',
          name: "C'est qui, mon experte Mixt ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "C'est votre interlocutrice au quotidien — l'incarnation, c'est Laetitia, cofondatrice et patiente elle-même depuis plus de 10 ans. Elle connaît intimement le parcours et les questions qu'on n'ose pas toujours poser (« est-ce normal que ça pique le matin ? », « je peux mettre ma crème anti-âge en même temps ? », « pourquoi je ne vois pas de résultats au bout de 2 semaines ? »). Son rôle est non médical, et c'est sa force : elle vous écoute, suit vos photos, vous explique les actifs prescrits, vous accompagne dans votre routine, et fait remonter à votre dermatologue toute question médicale qui le mérite. Un interlocuteur humain, qualifié, présent — qui connaît votre cas.",
          },
        },
        {
          '@type': 'Question',
          name: 'Y a-t-il un engagement ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Un engagement de 2 mois, puis résiliable à tout moment. Ces 2 mois correspondent au cycle de renouvellement d'une préparation magistrale classique : c'est le temps qu'il faut à votre peau pour répondre et à votre dermatologue pour faire un premier ajustement utile. Un suivi qui s'arrête au bout de deux semaines ne sert à rien — c'est justement ce qu'on veut éviter.",
          },
        },
        {
          '@type': 'Question',
          name: "Et si mon dermatologue ne prescrit pas de formule magistrale ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Votre dermatologue est seul décisionnaire médical. Selon votre cas, il peut prescrire une formule magistrale sur mesure, des traitements dermatologiques classiques (rétinoïdes, acide azélaïque, antibiotiques topiques…), ou recommander une approche essentiellement cosmétique. Dans tous les cas, votre abonnement garde tout son sens : c'est le suivi qui fait la différence — un dermatologue qui ajuste votre prise en charge en continu et une experte Mixt à vos côtés chaque semaine, quel que soit le traitement.",
          },
        },
        {
          '@type': 'Question',
          name: 'Et si le traitement ne me convient pas ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Si vous ressentez une intolérance, une gêne importante, ou des effets inattendus (rougeurs persistantes, brûlures, desquamation excessive), contactez votre experte Mixt — elle transmet immédiatement à votre dermatologue, qui ajuste sa prescription selon votre situation. Beaucoup d'effets que l'on prend pour des problèmes sont en réalité attendus dans les premières semaines : tiraillements, micro-desquamations, légères rougeurs, période d'adaptation. Notre rôle, c'est aussi de vous expliquer ce qui est normal, ce qui ne l'est pas, et quand il faut vraiment alerter votre médecin.",
          },
        },
        {
          '@type': 'Question',
          name: 'La formule magistrale est-elle remboursée ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Partiellement, selon les actifs prescrits et votre mutuelle. Votre pharmacie partenaire vous fournit une feuille de soins. C'est l'avantage d'une vraie prescription médicale, contrairement aux services 100 % à votre charge.",
          },
        },
        {
          '@type': 'Question',
          name: 'Comment mes données de santé sont-elles protégées ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Vos données sont hébergées sur une infrastructure certifiée HDS (Hébergeur de Données de Santé), conformément à la réglementation française, et soumises au secret médical.',
          },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Mixt — Suivi dermatologique continu | 29 €/mois, jamais seule"
  description="29 €/mois : un dermatologue qui ajuste et renouvelle votre traitement en continu, une experte Mixt à vos côtés chaque semaine. Accès sous une semaine. Rosacée, hyperpigmentation, acné, eczéma."
  ogTitle="Mixt — Votre peau, suivie en continu"
  ogDescription="Le suivi médical qui fait marcher votre traitement dans la durée : dermatologue qui ajuste en continu + experte Mixt chaque semaine. 29 €/mois."
  structuredData={structuredData}
>
  <Nav ctaLabel="Commencer" ctaHref="/premieres-patientes" />

  <V3Hero />
  <V3Problem />
  <V3Pillars />
  <V3Steps />
  <V3Respiration />
  <V3Conditions />
  <V3Science />
  <V3Testimonials />
  <V3Pricing />
  <V3Team />
  <V3FaqCta />

  <Footer />
</BaseLayout>
