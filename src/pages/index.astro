---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import V3Hero from '../components/sections-v3/V3Hero.astro';
import V3Problem from '../components/sections-v3/V3Problem.astro';
import V3Pillars from '../components/sections-v3/V3Pillars.astro';
import V3Steps from '../components/sections-v3/V3Steps.astro';
import V3Respiration from '../components/sections-v3/V3Respiration.astro';
import V3Conditions from '../components/sections-v3/V3Conditions.astro';
import V3Science from '../components/sections-v3/V3Science.astro';
import V3Testimonials from '../components/sections-v3/V3Testimonials.astro';
import V3Team from '../components/sections-v3/V3Team.astro';
import V3Pricing from '../components/sections-v3/V3Pricing.astro';
import V3FaqCta from '../components/sections-v3/V3FaqCta.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://mixt.care/#organization',
      name: 'Mixt',
      url: 'https://mixt.care',
      logo: 'https://mixt.care/favicons/android-chrome-512x512.png',
      description:
        'Service médical français de dermatologie en ligne. Téléconsultation, formulation magistrale personnalisée préparée en pharmacie partenaire, et suivi dermatologique continu pour les conditions chroniques de la peau.',
      founder: [
        { '@id': 'https://mixt.care/#laetitia' },
        { '@id': 'https://mixt.care/#boris' },
        { '@id': 'https://mixt.care/#bethsabee' },
      ],
    },
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://mixt.care/#medicalbusiness',
      name: 'Mixt',
      url: 'https://mixt.care',
      image: 'https://mixt.care/images/og-image.png',
      medicalSpecialty: 'Dermatology',
      availableService: [
        {
          '@type': 'MedicalTherapy',
          name: 'Téléconsultation dermatologique',
          description:
            'Consultation vidéo ou téléphonique avec un médecin pour évaluer votre peau, poser un diagnostic et prescrire un protocole personnalisé.',
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Formulation magistrale personnalisée',
          description:
            "Préparation en pharmacie partenaire sur ordonnance médicale, avec principes actifs choisis et dosés pour votre cas.",
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Accompagnement Mixt',
          description:
            "Photos mensuelles, accompagnement par l'équipe Mixt et bilan dermatologique à 3 mois pour renouveler ou ajuster la formule.",
        },
      ],
      areaServed: { '@type': 'Country', name: 'France' },
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#laetitia',
      name: 'Laetitia Payan',
      jobTitle: 'CEO & Co-fondatrice',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/laetitia-after.webp',
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#boris',
      name: 'Boris Paillard',
      jobTitle: 'CPO & Co-fondateur',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/boris.webp',
    },
    {
      '@type': 'Physician',
      '@id': 'https://mixt.care/#bethsabee',
      name: 'Dr Bethsabée Levy Garel',
      jobTitle: 'Dermatologue Fondatrice',
      medicalSpecialty: 'Dermatology',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/bethsabee.webp',
      alumniOf: 'Sorbonne Université',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://mixt.care/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: "Qu'est-ce que je paie exactement ? Et à qui ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Une seule fois à Mixt — 49 € : pour votre parcours de 3 mois (entretien de 30 min avec votre experte, dossier dermatologique structuré, mise en relation avec un dermatologue partenaire formé aux approches personnalisées, suivi par l'équipe, bilan à 3 mois). Le reste, comme dans tout parcours médical : votre consultation est facturée par votre dermatologue aux tarifs conventionnés, en partie remboursée par la Sécurité sociale ; si une formule magistrale est prescrite, sa préparation en pharmacie coûte 30 à 60 €, partiellement remboursée selon votre mutuelle. Vous savez exactement ce que vous payez, et à qui, dès le départ.",
          },
        },
        {
          '@type': 'Question',
          name: "Concrètement, qu'est-ce que je paie à Mixt ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Mixt prend en charge tout ce qu'il y a autour de la consultation dermatologique. 30 minutes avec votre experte pour structurer votre dossier — historique, traitements essayés, réactions, photos, contexte. Votre dermatologue dispose ainsi d'une vision complète avant la consultation, pour adapter finement sa décision clinique à votre cas. Entre les rendez-vous, l'équipe Mixt suit votre évolution, répond à vos questions et transmet à votre dermatologue les éléments utiles aux prochains ajustements. C'est la continuité et la structuration qui permettent à la dermatologie de donner le meilleur d'elle-même.",
          },
        },
        {
          '@type': 'Question',
          name: "Qu'est-ce que Mixt apporte de différent ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Trois choses que vous n'avez pas en cabinet aujourd'hui. Un accès rapide à un dermatologue : sous une semaine en moyenne via notre réseau partenaire. Un dossier dermatologique préparé en amont : 30 minutes avec votre experte pour permettre à votre dermatologue de comprendre votre cas en profondeur (antécédents, traitements essayés, réactions, rythme de vie, objectifs) ; avec cette vision complète, sa prise en charge peut être finement adaptée à votre profil. Un accompagnement humain pendant 3 mois : entre les consultations, l'équipe Mixt suit vos photos, répond à vos questions, vous guide dans l'application du traitement, et fait remonter à votre dermatologue tout ce qui mérite son attention. Mixt vient en complément du parcours médical : on le structure, on l'accélère, et on vous accompagne tout le long.",
          },
        },
        {
          '@type': 'Question',
          name: 'Vais-je échanger avec mon dermatologue pendant les 3 mois ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Votre dermatologue intervient à la consultation initiale : il évalue votre situation, échange avec vous, et établit son plan de traitement — qui peut inclure une formule magistrale sur mesure si votre cas le justifie. Entre cette consultation et la suivante, c'est l'équipe Mixt qui vous accompagne au quotidien : suivi de vos photos, réponses à vos questions sur la routine, l'application, les sensations ressenties, ce à quoi vous attendre dans les premières semaines. Pour toute nouvelle question médicale, une consultation supplémentaire reste possible. L'idée : vous ne soyez jamais seul·e face à votre peau, sans transformer chaque doute en nouveau rendez-vous.",
          },
        },
        {
          '@type': 'Question',
          name: 'Qui est mon dermatologue Mixt ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Un dermatologue diplômé, inscrit à l'Ordre des Médecins, avec un RPPS vérifiable. Sélectionné pour son expertise en dermatologie personnalisée et sa maîtrise des approches sur mesure, notamment la formulation magistrale. Vous le rencontrez en téléconsultation lors de la consultation initiale. Pour les échanges du quotidien, c'est l'équipe Mixt qui vous répond et fait le lien avec votre dermatologue quand c'est utile.",
          },
        },
        {
          '@type': 'Question',
          name: "Qui est l'équipe Mixt qui m'accompagne au quotidien ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "L'équipe Mixt, c'est d'abord Laetitia — cofondatrice, patiente elle-même depuis plus de 10 ans. Elle connaît intimement le parcours, les questions qu'on n'ose pas toujours poser à son dermatologue. Elle est aussi une référence sur la science des actifs et des formulations magistrales : 15 ans de littérature scientifique étudiée, des dizaines d'heures de recherche chaque semaine. Notre rôle est non médical, et c'est sa force : on vous écoute, on suit vos photos, on vous explique les actifs prescrits, on vous accompagne dans la routine au quotidien, et on fait remonter à votre dermatologue toute question médicale qui mérite son attention. Un interlocuteur humain, qualifié, présent — qui connaît votre cas. C'est exactement ce qui manque dans le parcours dermato classique.",
          },
        },
        {
          '@type': 'Question',
          name: "Et si mon dermatologue ne prescrit pas de formule magistrale ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Votre dermatologue est seul décisionnaire médical. Selon votre cas, il peut prescrire une formule magistrale sur mesure, une prescription dermatologique classique, ou recommander une approche cosmétique. Sa décision est adaptée à votre situation clinique, pas à un protocole standard. Quelle que soit sa décision, le parcours Mixt reste utile : votre consultation aura été préparée par un dossier complet, et notre équipe vous accompagne dans la prise en main et le suivi de la routine recommandée. La force du parcours Mixt, c'est justement de permettre à chaque cas d'être traité à sa juste mesure.",
          },
        },
        {
          '@type': 'Question',
          name: 'Comment se passe le bilan à 3 mois ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "À la fin de votre parcours, l'équipe Mixt fait le point avec vous : ressenti, observance, photos, évolution observée. Ce bilan est inclus dans votre forfait. Il sert à préparer votre prochaine consultation dermatologique : ce qui a fonctionné, ce qui mérite d'être ajusté, les questions à poser. À partir de votre dossier mis à jour, votre dermatologue pourra renouveler votre traitement, l'ajuster, ou faire évoluer son approche selon ce que les 3 mois lui ont appris sur votre peau. Un moment structuré entre vous et votre médecin, pour que la décision suivante soit informée par tout ce qui s'est passé entre les deux consultations.",
          },
        },
        {
          '@type': 'Question',
          name: 'Et si la formule ne me convient pas ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Si vous ressentez une intolérance, une gêne importante, ou des effets inattendus en cours de traitement, contactez l'équipe Mixt — on transmet immédiatement à votre dermatologue. Il pourra alors, dans le cadre d'une consultation de suivi, ajuster sa prescription selon votre situation. Beaucoup d'effets que les patients prennent pour des problèmes sont en réalité attendus dans les premières semaines : tiraillements, micro-réactions, période d'adaptation. Notre rôle, c'est aussi de vous expliquer ce qui est normal, ce qui ne l'est pas, et quand il faut vraiment alerter votre médecin.",
          },
        },
        {
          '@type': 'Question',
          name: 'La formule magistrale est-elle remboursée ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Partiellement, selon les actifs prescrits et votre mutuelle. Votre pharmacie partenaire vous fournit une feuille de soins.',
          },
        },
        {
          '@type': 'Question',
          name: 'Comment mes données de santé sont-elles protégées ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Vos données sont hébergées sur une infrastructure certifiée HDS (Hébergeur de Données de Santé), conformément à la réglementation française, et soumises au secret médical.',
          },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Mixt — Programme dermatologique 12 semaines | Suivi 1:1 + formule magistrale"
  description="Un dermatologue analyse votre peau, construit votre protocole personnalisé, et l'ajuste semaine après semaine. Rosacée, hyperpigmentation, acné, eczéma — traitement sur ordonnance + suivi continu."
  ogTitle="Mixt — Votre peau mérite un vrai suivi médical"
  ogDescription="Programme dermato 12 semaines : consultation + formule magistrale personnalisée + suivi 1:1 avec ajustement de formule."
  structuredData={structuredData}
>
  <Nav ctaLabel="Commencer" ctaHref="/premieres-patientes" />

  <V3Hero />
  <V3Problem />
  <V3Pillars />
  <V3Steps />
  <V3Respiration />
  <V3Conditions />
  <V3Science />
  <V3Testimonials />
  <V3Pricing />
  <V3Team />
  <V3FaqCta />

  <Footer />
</BaseLayout>
