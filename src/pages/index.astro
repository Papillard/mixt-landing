---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import V3Hero from '../components/sections-v3/V3Hero.astro';
import V3Problem from '../components/sections-v3/V3Problem.astro';
import V3Pillars from '../components/sections-v3/V3Pillars.astro';
import V3Steps from '../components/sections-v3/V3Steps.astro';
import V3Respiration from '../components/sections-v3/V3Respiration.astro';
import V3Conditions from '../components/sections-v3/V3Conditions.astro';
import V3Science from '../components/sections-v3/V3Science.astro';
import V3Testimonials from '../components/sections-v3/V3Testimonials.astro';
import V3Team from '../components/sections-v3/V3Team.astro';
import V3Pricing from '../components/sections-v3/V3Pricing.astro';
import V3FaqCta from '../components/sections-v3/V3FaqCta.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://mixt.care/#organization',
      name: 'Mixt',
      url: 'https://mixt.care',
      logo: 'https://mixt.care/favicons/android-chrome-512x512.png',
      description:
        'Service médical français de dermatologie en ligne. Téléconsultation, formulation magistrale personnalisée préparée en pharmacie partenaire, et suivi dermatologique continu pour les conditions chroniques de la peau.',
      founder: [
        { '@id': 'https://mixt.care/#laetitia' },
        { '@id': 'https://mixt.care/#boris' },
        { '@id': 'https://mixt.care/#bethsabee' },
      ],
    },
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://mixt.care/#medicalbusiness',
      name: 'Mixt',
      url: 'https://mixt.care',
      image: 'https://mixt.care/images/og-image.png',
      medicalSpecialty: 'Dermatology',
      availableService: [
        {
          '@type': 'MedicalTherapy',
          name: 'Téléconsultation dermatologique',
          description:
            'Consultation vidéo ou téléphonique avec un médecin pour évaluer votre peau, poser un diagnostic et prescrire un protocole personnalisé.',
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Formulation magistrale personnalisée',
          description:
            "Préparation en pharmacie partenaire sur ordonnance médicale, avec principes actifs choisis et dosés pour votre cas.",
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Suivi médical mensuel',
          description:
            "Accompagnement quotidien par l'IA et point mensuel avec votre médecin pour renouveler ou ajuster le traitement. Optionnel, sans engagement.",
        },
      ],
      areaServed: { '@type': 'Country', name: 'France' },
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#laetitia',
      name: 'Laetitia Payan',
      jobTitle: 'CEO & Co-fondatrice',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/laetitia-after.webp',
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#boris',
      name: 'Boris Paillard',
      jobTitle: 'CPO & Co-fondateur',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/boris.webp',
    },
    {
      '@type': 'Physician',
      '@id': 'https://mixt.care/#bethsabee',
      name: 'Dr Bethsabée Levy Garel',
      jobTitle: 'Dermatologue Fondatrice',
      medicalSpecialty: 'Dermatology',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/bethsabee.webp',
      alumniOf: 'Sorbonne Université',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://mixt.care/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: "Combien ça coûte, et à qui ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Le bilan en ligne est gratuit : vous le faites avec notre assistant IA et repartez avec un dossier dermatologique structuré, à vous. La première téléconsultation coûte 59 €, réglés à Mixt : ce montant couvre les honoraires du médecin et les frais de service Mixt. Vous ne payez que si vous décidez de réserver. La formule magistrale, si elle est prescrite, est facturée 30 à 60 € par votre pharmacie, partiellement remboursée selon votre mutuelle. Le suivi dans la durée est optionnel : dès 29 €/mois, sans engagement, résiliable à tout moment.",
          },
        },
        {
          '@type': 'Question',
          name: "Le bilan est-il vraiment gratuit ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Oui. Vous pouvez faire votre bilan en ligne et obtenir votre dossier dermatologique structuré sans rien payer. Vous ne réglez les 59 € que si vous choisissez de réserver votre téléconsultation à l'issue du bilan.",
          },
        },
        {
          '@type': 'Question',
          name: 'Qui est le médecin ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Un médecin généraliste diplômé, inscrit à l'Ordre des Médecins, avec un RPPS vérifiable, formé à une approche globale de la peau. Pour les cas qui le nécessitent, il s'appuie sur notre comité de dermatologues. Vous le rencontrez en téléconsultation, et c'est lui qui assure ensuite votre suivi mensuel si vous continuez.",
          },
        },
        {
          '@type': 'Question',
          name: 'Comment fonctionne la consultation médicale ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "C'est une consultation augmentée. Votre médecin arrive avec tout votre dossier déjà en main : il ne perd pas 15 minutes à le reconstituer. Formé à une approche globale, il s'appuie sur notre comité de dermatologues pour les cas qui le nécessitent, et vous suit dans la durée. Résultat : une consultation dense, préparée, dédiée à votre plan de traitement.",
          },
        },
        {
          '@type': 'Question',
          name: 'Mes données et mes photos sont-elles protégées ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Oui. Vos données (vos photos comprises) sont hébergées sur des serveurs certifiés HDS (Hébergeur de Données de Santé) en France, et soumises au secret médical. Vos photos ne sont jamais transmises à l'IA ni à aucun tiers : elles restent dans votre dossier sécurisé, et seul le médecin que vous consultez peut les ouvrir, uniquement une fois votre rendez-vous réservé, jamais avant.",
          },
        },
        {
          '@type': 'Question',
          name: "Suis-je obligé·e de prendre un abonnement ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Non. La première téléconsultation se suffit à elle-même : vous repartez avec votre plan de traitement, c'est à vous, vous pouvez vous arrêter là. Le suivi dans la durée est entièrement optionnel, sans engagement, et résiliable à tout moment.",
          },
        },
        {
          '@type': 'Question',
          name: "En quoi consiste le suivi mensuel ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Deux niveaux d'accompagnement. Au quotidien, l'IA suit votre peau, tient votre journal et répond à vos questions pratiques. Et chaque mois, votre médecin fait le point avec vous, puis renouvelle ou ajuste votre traitement si besoin. C'est un acte médical, réalisé par le médecin, pas par l'IA.",
          },
        },
        {
          '@type': 'Question',
          name: "Aurai-je forcément une ordonnance ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "La prescription relève de la seule décision du médecin. Selon votre cas, il peut prescrire une formule magistrale sur mesure, un traitement dermatologique classique, ou recommander une approche essentiellement cosmétique. Dans tous les cas, vous repartez avec un avis médical personnalisé et un plan clair pour votre peau.",
          },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Mixt · Votre dossier dermatologique en ligne | Téléconsultation + formule sur mesure"
  description="Créez votre dossier dermatologique gratuit en ligne. Un médecin, appuyé par notre comité de dermatologues, construit votre plan de traitement personnalisé : formule magistrale sur mesure si besoin. Rosacée, hyperpigmentation, acné, eczéma."
  ogTitle="Mixt · Votre peau mérite un vrai suivi médical"
  ogDescription="Bilan gratuit en ligne, téléconsultation à 59 €, formule magistrale personnalisée et suivi mensuel par votre médecin. Sans engagement."
  structuredData={structuredData}
>
  <Nav ctaLabel="Créer mon dossier" ctaHref="/premieres-patientes" />

  <V3Hero />
  <V3Problem />
  <V3Pillars />
  <V3Steps />
  <V3Respiration />
  <V3Conditions />
  <V3Science />
  <V3Testimonials />
  <V3Pricing />
  <V3Team />
  <V3FaqCta />

  <Footer />
</BaseLayout>
