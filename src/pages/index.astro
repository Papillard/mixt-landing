---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import V3Hero from '../components/sections-v3/V3Hero.astro';
import V3Problem from '../components/sections-v3/V3Problem.astro';
import V3Pillars from '../components/sections-v3/V3Pillars.astro';
import V3Steps from '../components/sections-v3/V3Steps.astro';
import V3Respiration from '../components/sections-v3/V3Respiration.astro';
import V3Conditions from '../components/sections-v3/V3Conditions.astro';
import V3Science from '../components/sections-v3/V3Science.astro';
import V3Testimonials from '../components/sections-v3/V3Testimonials.astro';
import V3Team from '../components/sections-v3/V3Team.astro';
import V3Pricing from '../components/sections-v3/V3Pricing.astro';
import V3FaqCta from '../components/sections-v3/V3FaqCta.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://mixt.care/#organization',
      name: 'Mixt',
      url: 'https://mixt.care',
      logo: 'https://mixt.care/favicons/android-chrome-512x512.png',
      description:
        'Service médical français de dermatologie en ligne. Téléconsultation, formulation magistrale personnalisée préparée en pharmacie partenaire, et suivi dermatologique continu pour les conditions chroniques de la peau.',
      founder: [
        { '@id': 'https://mixt.care/#laetitia' },
        { '@id': 'https://mixt.care/#boris' },
        { '@id': 'https://mixt.care/#bethsabee' },
      ],
    },
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://mixt.care/#medicalbusiness',
      name: 'Mixt',
      url: 'https://mixt.care',
      image: 'https://mixt.care/images/og-image.png',
      medicalSpecialty: 'Dermatology',
      availableService: [
        {
          '@type': 'MedicalTherapy',
          name: 'Téléconsultation dermatologique',
          description:
            'Consultation vidéo ou téléphonique avec un médecin pour évaluer votre peau, poser un diagnostic et prescrire un protocole personnalisé.',
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Formulation magistrale personnalisée',
          description:
            "Préparation en pharmacie partenaire sur ordonnance médicale, avec principes actifs choisis et dosés pour votre cas.",
        },
        {
          '@type': 'MedicalTherapy',
          name: 'Accompagnement Mixt',
          description:
            "Photos mensuelles, accompagnement par l'équipe Mixt et bilan dermatologique à 3 mois pour renouveler ou ajuster la formule.",
        },
      ],
      areaServed: { '@type': 'Country', name: 'France' },
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#laetitia',
      name: 'Laetitia Payan',
      jobTitle: 'CEO & Co-fondatrice',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/laetitia-after.webp',
    },
    {
      '@type': 'Person',
      '@id': 'https://mixt.care/#boris',
      name: 'Boris Paillard',
      jobTitle: 'CPO & Co-fondateur',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/boris.webp',
    },
    {
      '@type': 'Physician',
      '@id': 'https://mixt.care/#bethsabee',
      name: 'Dr Bethsabée Levy Garel',
      jobTitle: 'Dermatologue Fondatrice',
      medicalSpecialty: 'Dermatology',
      worksFor: { '@id': 'https://mixt.care/#organization' },
      image: 'https://mixt.care/images/bethsabee.webp',
      alumniOf: 'Sorbonne Université',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://mixt.care/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Vais-je échanger avec mon dermatologue pendant les 3 mois ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Votre dermatologue intervient à deux moments clés : la consultation initiale, où il vous prescrit votre formule personnalisée, et le bilan à 3 mois, où il évalue votre évolution à partir de vos photos et décide de renouveler ou d'ajuster votre formule. Entre les deux, l'équipe Mixt vous accompagne au quotidien : suivi de vos photos mensuelles, conseils pratiques, encouragements. Pour une nouvelle question médicale en cours de parcours, une consultation supplémentaire est possible.",
          },
        },
        {
          '@type': 'Question',
          name: "Qu'est-ce que Mixt apporte en plus d'une consultation classique ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Trois choses que vous n'avez pas en cabinet aujourd'hui : un délai d'une semaine au lieu de plusieurs mois, une formule magistrale sur-mesure plutôt qu'une ordonnance générique, et un accompagnement humain par notre équipe pendant 3 mois pour aller au bout de votre traitement. On ne remplace pas le parcours médical classique : on le rend accessible et on vous tient la main entre les RDV.",
          },
        },
        {
          '@type': 'Question',
          name: 'Qui est mon dermatologue Mixt ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Un dermatologue diplômé, inscrit à l'Ordre des Médecins, avec un RPPS vérifiable. Pas un algorithme. Vous le rencontrez en téléconsultation lors de la consultation initiale, et à nouveau lors du bilan à 3 mois. Pour les échanges du quotidien, c'est l'équipe Mixt qui vous répond et fait le lien avec votre dermatologue si nécessaire.",
          },
        },
        {
          '@type': 'Question',
          name: "Qui est l'équipe Mixt qui m'accompagne au quotidien ?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "L'équipe Mixt — Laetitia (cofondatrice et patiente depuis 10 ans) et notre équipe d'accompagnement — vous suit au quotidien pendant 3 mois. Elle ne pose pas de diagnostic et ne donne pas d'avis médical : son rôle est de vous écouter, de suivre vos photos, de vous conseiller sur l'application et de faire remonter à votre dermatologue toute question médicale qui le nécessite.",
          },
        },
        {
          '@type': 'Question',
          name: 'Et si la formule ne me convient pas ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Si vous ressentez une intolérance ou une gêne importante en cours de traitement, contactez l'équipe Mixt qui transmettra immédiatement à votre dermatologue. Il pourra alors, selon votre situation, ajuster la formule via une nouvelle prescription. L'ajustement programmé est inclus dans votre bilan à 3 mois, sans surcoût.",
          },
        },
        {
          '@type': 'Question',
          name: 'Comment se passe le bilan à 3 mois ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "À la fin de votre parcours, votre dermatologue revoit l'ensemble de votre évolution : vos photos mensuelles, votre ressenti, l'efficacité observée. Il décide alors soit de renouveler votre formule pour 3 mois supplémentaires si elle vous convient bien, soit de l'ajuster pour la suite. Ce bilan est inclus dans votre forfait.",
          },
        },
        {
          '@type': 'Question',
          name: 'Comment mes données de santé sont-elles protégées ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Vos données sont hébergées sur une infrastructure certifiée HDS (Hébergeur de Données de Santé), conformément à la réglementation française, et soumises au secret médical.',
          },
        },
        {
          '@type': 'Question',
          name: 'La formule magistrale est-elle remboursée ?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Partiellement, selon les actifs prescrits et votre mutuelle. Votre pharmacie partenaire vous fournit une feuille de soins.',
          },
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Mixt — Programme dermatologique 12 semaines | Suivi 1:1 + formule magistrale"
  description="Un dermatologue analyse votre peau, construit votre protocole personnalisé, et l'ajuste semaine après semaine. Rosacée, hyperpigmentation, acné, eczéma — traitement sur ordonnance + suivi continu."
  ogTitle="Mixt — Votre peau mérite un vrai suivi médical"
  ogDescription="Programme dermato 12 semaines : consultation + formule magistrale personnalisée + suivi 1:1 avec ajustement de formule."
  structuredData={structuredData}
>
  <Nav ctaLabel="Commencer" ctaHref="/premieres-patientes" />

  <V3Hero />
  <V3Problem />
  <V3Pillars />
  <V3Steps />
  <V3Respiration />
  <V3Conditions />
  <V3Science />
  <V3Testimonials />
  <V3Team />
  <V3Pricing />
  <V3FaqCta />

  <Footer />
</BaseLayout>
