---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Page introuvable — Mixt"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
>
  <Nav ctaLabel="Commencer" ctaHref="/premieres-patientes" />

  <section class="px-6 md:px-10 pt-[calc(56px+120px)] pb-24 md:pb-32 bg-base min-h-[70vh] flex items-center">
    <div class="max-w-[720px] mx-auto text-center">
      <div class="flex items-center justify-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ember-deep mb-6">
        <span class="inline-block h-px w-10 bg-ember-deep/80"></span>
        Erreur 404
        <span class="inline-block h-px w-10 bg-ember-deep/80"></span>
      </div>
      <h1 class="text-[48px] md:text-[64px] font-medium leading-[1.05] tracking-[-0.035em] text-ink mb-6">
        Cette page a <span class="italic-serif whitespace-nowrap">disparu.</span>
      </h1>
      <p class="text-[17px] md:text-lg leading-relaxed text-ink-2 mb-10 max-w-[500px] mx-auto">
        Le lien que vous avez suivi n'existe plus, ou l'adresse est incorrecte.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button href="/" variant="dark">Retour à l'accueil →</Button>
        <Button href="/premieres-patientes" variant="ghost">Commencer mon bilan</Button>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
