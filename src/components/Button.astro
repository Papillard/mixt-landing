---
interface Props {
  href?: string;
  variant?: 'dark' | 'white' | 'ghost' | 'ghost-light' | 'ember' | 'ember-pill';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'dark',
  size = 'lg',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center gap-2 font-semibold no-underline cursor-pointer rounded-full transition-all duration-200 border';

const sizeMap = {
  sm: 'px-4 py-2 text-[13px]',
  md: 'px-5 py-3 text-sm',
  lg: 'px-[28px] py-[13px] text-[15px]',
};

const variantMap = {
  dark: 'bg-deep text-white border-deep hover:bg-[#2B1018]',
  white: 'bg-white text-ink border-white hover:bg-[#f5f5f5]',
  ghost: 'bg-transparent text-ink border-ink/15 hover:border-ink/40',
  'ghost-light': 'bg-transparent text-white border-white/25 hover:border-white/60',
  ember: 'bg-ember text-white border-ember hover:bg-ember-dark shadow-[0_2px_14px_-2px_rgba(212,98,42,0.35)]',
  'ember-pill': 'bg-ember text-white border-ember hover:bg-ember-dark shadow-[0_2px_14px_-2px_rgba(212,98,42,0.35)]',
};

const Tag = href ? 'a' : 'button';
const classes = `${base} ${sizeMap[size]} ${variantMap[variant]} ${className}`;
---

<Tag class={classes} href={href} {...rest}>
  <slot />
</Tag>
