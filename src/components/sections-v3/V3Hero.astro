---
import Button from '../Button.astro';
import HeroReveal from '../motion/HeroReveal.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';
import HeroMasiChart from '../motion/HeroMasiChart.tsx';
---

<section class="relative px-6 md:px-10 pt-[calc(56px+80px)] pb-20 md:pb-28 bg-base">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-12 lg:gap-16 items-center">
    <div>
      <HeroReveal
        client:load
        eyebrow="Parcours dermatologique continu"
        eyebrowMono={true}
        title="Reprenez la main"
        highlight="sur votre peau."
        subtitle="Un dermatologue accessible sous une semaine, qui vous comprend vraiment, et une équipe à vos côtés tout au long du parcours."
      >
        <div class="flex flex-wrap items-center gap-3">
          <Button href="/premieres-patientes" variant="ember-pill">Trouver mon dermatologue →</Button>
          <Button href="#approche" variant="ghost">Nous parler 20 min →</Button>
        </div>
      </HeroReveal>

      <FadeInSection client:load delay={0.55} y={14} className="mt-12 pt-6 border-t border-ink/10">
        <div class="grid grid-cols-1 sm:grid-cols-3 sm:gap-3 items-start">
          <div class="flex items-baseline justify-between gap-4 sm:block py-3 sm:py-0 sm:pr-3 border-b sm:border-b-0 sm:border-r border-ink/10">
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight sm:mb-1.5 tracking-[-0.01em]">30 min</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">De préparation 1:1 avec votre experte</div>
          </div>
          <div class="flex items-baseline justify-between gap-4 sm:block py-3 sm:py-0 sm:pr-3 border-b sm:border-b-0 sm:border-r border-ink/10">
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight sm:mb-1.5 tracking-[-0.01em]">Dermatologue expert</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">En dermatologie personnalisée</div>
          </div>
          <div class="flex items-baseline justify-between gap-4 sm:block py-3 sm:py-0">
            <div class="font-mono text-[14px] md:text-[16px] font-medium text-ink leading-tight sm:mb-1.5 tracking-[-0.01em]">Au quotidien</div>
            <div class="font-mono text-[10.5px] uppercase tracking-[0.1em] text-ink-3">Accompagnement par l'équipe Mixt</div>
          </div>
        </div>
      </FadeInSection>
    </div>

    <FadeInSection client:load delay={0.25} y={24}>
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-blush/30 shadow-[0_20px_60px_-20px_rgba(54,24,34,0.35)]">
        <img
          src="/images/hero-new.jpg"
          alt="Portrait d'une patiente Mixt"
          class="absolute inset-0 h-full w-full object-cover object-[center_30%]"
          fetchpriority="high"
        />
        {/* Gradient sombre ultra-léger bottom-left pour lisibilité du graph sans dénaturer la photo */}
        <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 65% 60% at 0% 100%, rgba(26,18,16,0.22) 0%, rgba(26,18,16,0.08) 35%, transparent 65%);"></div>

        {/* Chip marron top-left */}
        <div class="absolute left-5 top-5 z-[5] rounded-[6px] bg-deep/95 backdrop-blur px-3 py-1.5 text-[10px] font-semibold tracking-[0.18em] uppercase text-white">
          Mélasma
        </div>

        {/* Graph MASI overlay */}
        <HeroMasiChart client:load />
      </div>
    </FadeInSection>
  </div>
</section>
