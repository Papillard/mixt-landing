---
import ConditionTabs from '../motion/ConditionTabs.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';

const tabs = [
  {
    id: 'hyperpigmentation',
    label: 'Hyperpigmentation',
    image: '/images/hyperpigmentation.webp',
    imageAlt: 'Hyperpigmentation, peau avec taches brunes',
    chip: 'Hyperpigmentation',
    pedagogy: {
      lede: "Une tache brune, c'est de la mélanine qui s'accumule dans la peau.",
      body: "Fabriquée en profondeur, elle remonte à la surface puis s'évacue. Quand le cycle se dérègle (UV, hormones, inflammation), elle s'installe. La dermatologie agit sur ces trois temps : freiner, ralentir, évacuer.",
    },
    actifs: [
      { name: 'Acide azélaïque', bold: 'Agit sur la production de mélanine', rest: "et l'inflammation." },
      { name: 'Acide kojique', bold: 'Agit sur la production de mélanine.' },
      { name: 'Acide tranexamique', bold: 'Agit sur le transfert', rest: 'vers la surface.' },
      { name: 'Niacinamide', bold: 'Agit sur le transfert', rest: 'vers la surface.' },
      { name: 'Acide rétinoïque', bold: 'Agit sur le renouvellement', rest: 'cellulaire.' },
    ],
    footer:
      "Le médecin choisit les actifs et dosages adaptés à chaque patient, selon son évaluation clinique.",
    disclaimer: '',
  },
  {
    id: 'acne',
    label: 'Acné',
    image: '/images/acne.webp',
    imageAlt: 'Acné, peau avec imperfections',
    chip: 'Acné',
    pedagogy: {
      lede: "L'acné, c'est un follicule qui se bouche, puis s'enflamme.",
      body: "Trop de sébum, des cellules mortes qui s'accumulent, une bactérie qui prolifère, et l'inflammation s'installe. La dermatologie agit sur chaque maillon : désincruster le pore, réguler le sébum, calmer l'inflammation.",
    },
    actifs: [
      { name: 'Acide salicylique', bold: 'Désincruste le pore', rest: 'et exfolie en douceur.' },
      { name: 'Rétinoïdes', bold: 'Renouvellent la peau', rest: 'et préviennent les comédons.' },
      { name: 'Acide azélaïque', bold: 'Antibactérien', rest: 'et anti-inflammatoire.' },
      { name: 'Zinc', bold: 'Régule le sébum', rest: 'et apaise.' },
      { name: 'Niacinamide', bold: "Calme l'inflammation", rest: 'et resserre le grain de peau.' },
    ],
    footer: 'Le médecin choisit les actifs et dosages adaptés à chaque patient, selon son évaluation clinique.',
    disclaimer: '',
  },
  {
    id: 'rosacea',
    label: 'Rosacée',
    image: '/images/rosacea.webp',
    imageAlt: 'Rosacée, peau avec rougeurs diffuses',
    chip: 'Rosacée',
    pedagogy: {
      lede: "La rosacée, c'est une peau qui rougit et s'enflamme facilement.",
      body: "Des vaisseaux hyperréactifs, une inflammation chronique, parfois des boutons : plusieurs mécanismes se combinent. La dermatologie cible chacun pour apaiser durablement la peau.",
    },
    actifs: [
      { name: 'Métronidazole', bold: "Réduit l'inflammation", rest: 'et les boutons. Référence de première intention.' },
      { name: 'Acide azélaïque', bold: 'Anti-inflammatoire', rest: 'parmi les plus efficaces sur les lésions.' },
      { name: 'Ivermectine', bold: "Cible l'inflammation", rest: 'et les micro-organismes de la peau.' },
      { name: 'Niacinamide', bold: 'Renforce la barrière', rest: 'et apaise les rougeurs.' },
    ],
    footer: 'Le médecin choisit les actifs et dosages adaptés à chaque patient, selon son évaluation clinique.',
    disclaimer: '',
  },
  {
    id: 'eczema',
    label: 'Eczéma',
    image: '/images/eczema.webp',
    imageAlt: 'Peau avec eczéma',
    chip: 'Eczéma',
    pedagogy: {
      lede: "L'eczéma, c'est une barrière cutanée fragilisée qui s'enflamme.",
      body: "Trop perméable, la peau laisse passer irritants et allergènes : elle s'assèche, démange et s'enflamme par poussées. La dermatologie répare la barrière et calme l'inflammation.",
    },
    actifs: [
      { name: 'Émollients et urée', bold: 'Réparent la barrière', rest: 'et hydratent en profondeur.' },
      { name: 'Dermocorticoïdes', bold: "Calment l'inflammation", rest: 'des poussées.' },
      { name: 'Tacrolimus', bold: 'Anti-inflammatoire sans corticoïde', rest: 'pour les zones sensibles.' },
      { name: 'Niacinamide', bold: 'Renforce la barrière', rest: 'et limite la perte en eau.' },
    ],
    footer: 'Le médecin choisit les actifs et dosages adaptés à chaque patient, selon son évaluation clinique.',
    disclaimer: '',
  },
];
---

<section id="conditions" class="px-6 md:px-10 py-24 md:py-32 bg-cream">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-violet mb-5">
        <span class="inline-block h-px w-10 bg-violet/80"></span>
        La science dermatologique
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] max-w-[820px] mb-4 text-ink">
        Ce que la dermatologie <span class="italic-serif">sait faire</span> pour votre peau.
      </h2>
      <p class="text-[16px] leading-[1.6] text-ink-2 max-w-[520px] mb-14">
        Les actifs, les mécanismes, expliqués sans jargon.
      </p>
    </FadeInSection>

    <ConditionTabs client:load tabs={tabs} />

    <FadeInSection client:load>
      <div class="mt-14 pt-8 border-t border-black/[0.08] text-center text-[14px] text-ink-2 italic max-w-[720px] mx-auto leading-relaxed">
        Ces actifs ne sont pas disponibles en cosmétique. Ils sont prescrits et préparés en pharmacie sur ordonnance médicale.
      </div>
    </FadeInSection>
  </div>
</section>
