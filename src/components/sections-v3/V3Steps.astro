---
import StickySteps from '../motion/StickySteps.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';

const steps = [
  {
    number: '01',
    title: 'Créez votre dossier dermatologique',
    desc: "30 minutes en visio avec votre experte Mixt : antécédents, traitements essayés, photos, objectifs. Votre dermatologue reçoit tout pour poser votre prise en charge. Données protégées, hébergées en France.",
  },
  {
    number: '02',
    title: 'Votre dermatologue pose votre traitement',
    desc: "Sous une semaine, votre dermatologue valide et propose votre plan personnalisé : les bons actifs, bien dosés, adaptés à votre peau et à vos objectifs. Une formule magistrale sur mesure si votre cas le justifie.",
  },
  {
    number: '03',
    title: 'On le suit et on l\'ajuste, en continu',
    desc: "Chaque semaine, votre experte Mixt suit vos photos et vos questions. En appui, votre dermatologue renouvelle et ajuste votre traitement au fil du temps — et intervient si besoin. Vous n'êtes jamais seule.",
  },
  {
    number: '04',
    title: 'Votre suivi évolue avec votre peau',
    desc: "Photos régulières, messagerie ouverte, suivi par votre experte Mixt. Votre traitement est renouvelé et ajusté à chaque cycle, aussi longtemps que votre peau en a besoin.",
  },
];

const panels = [
  {
    label: 'Étape 01',
    kind: 'image' as const,
    src: '/images/woman-mirror-melasma.jpg',
    alt: 'Auto-observation de sa peau au miroir',
  },
  {
    label: 'Étape 02',
    kind: 'image' as const,
    src: '/images/step-02-consultation.jpg',
    alt: 'Téléconsultation avec la dermatologue depuis chez soi',
  },
  {
    label: 'Étape 03',
    kind: 'image' as const,
    src: '/images/step-03-preparation.jpg',
    alt: 'Préparation de la formule magistrale en pharmacie partenaire',
  },
  {
    label: 'Étape 04',
    kind: 'journal' as const,
    chartRows: [
      { when: 'Semaine 4', what: 'Premier point photo' },
      { when: 'Semaine 8', what: 'Renouvellement, formule ajustée' },
      { when: 'En continu', what: 'Suivi par votre experte Mixt' },
    ],
  },
];
---

<section class="px-6 md:px-10 py-24 md:py-32 bg-base">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-ember-deep mb-5">
        <span class="inline-block h-px w-10 bg-ember-deep/80"></span>
        Le parcours
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] max-w-[720px] mb-5 text-ink">
        Comment <span class="italic-serif">ça marche.</span>
      </h2>
      <p class="text-[17px] md:text-lg leading-relaxed text-ink-2 max-w-[640px] mb-14 md:mb-20">
        Quatre étapes pensées pour que la dermatologie travaille vraiment pour vous.
      </p>
    </FadeInSection>

    <StickySteps client:load steps={steps} panels={panels} />

    <FadeInSection client:load>
      <div class="flex justify-center mt-20 md:mt-28">
        <div class="inline-flex flex-col md:flex-row md:flex-wrap items-center md:justify-center gap-2.5 md:gap-[18px] px-5 py-3 md:px-[22px] md:py-[14px] rounded-2xl md:rounded-full border border-ink/[0.12] bg-base/70 backdrop-blur-md text-center md:text-left max-w-[340px] md:max-w-none">
          <span class="inline-flex items-center gap-[7px] font-mono text-[11px] tracking-[0.16em] uppercase text-jade-deep font-medium">
            <span class="inline-block w-[6px] h-[6px] rounded-full bg-jade shadow-[0_0_0_3px_rgba(95,191,163,0.18)]"></span>
            HDS · France
          </span>
          <span class="text-[13px] md:text-[14px] text-ink font-medium leading-snug">Vos données sont sécurisées et soumises au secret médical.</span>
          <span class="hidden md:inline-block w-px h-[14px] bg-ink/[0.12]"></span>
          <a href="/politique-de-confidentialite" class="hidden md:inline-flex items-center gap-[5px] text-[13px] text-ink-2 hover:text-ink font-medium transition-colors">
            En savoir plus <span aria-hidden>→</span>
          </a>
        </div>
      </div>
    </FadeInSection>
  </div>
</section>
