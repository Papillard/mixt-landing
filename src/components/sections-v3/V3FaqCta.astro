---
import Accordion from '../motion/Accordion.tsx';
import Button from '../Button.astro';
import FadeInSection from '../motion/FadeInSection.tsx';

const faq = [
  {
    q: "Combien ça coûte, et à qui ?",
    a: [
      {
        heading: 'Le bilan en ligne : gratuit',
        body: "Vous le faites avec notre assistant IA et repartez avec un dossier dermatologique structuré, à vous.",
      },
      {
        heading: 'La première consultation : 59 €',
        body: "Ces 59 € reviennent intégralement au médecin : Mixt ne prélève aucun frais dessus. Le bilan en ligne, le dossier structuré et la coordination vous sont offerts. Vous ne payez que si vous décidez de réserver.",
      },
      {
        heading: 'La formule magistrale, si prescrite : 30 à 60 €',
        body: "Facturée par votre pharmacie, partiellement remboursée selon votre mutuelle.",
      },
      {
        heading: 'Le suivi, si vous continuez',
        body: "Le suivi avec l'assistant IA Mixt est inclus. Le suivi par le médecin (point mensuel pour adapter ou renouveler votre plan) est à 29 €/mois, optionnel, sans engagement, résiliable à tout moment. Vous décidez après votre consultation.",
      },
    ],
  },
  {
    q: "Le bilan est-il vraiment gratuit ?",
    a: "Oui. Vous pouvez faire votre bilan en ligne et obtenir votre dossier dermatologique structuré sans rien payer. Vous ne réglez les 59 € que si vous choisissez de réserver votre téléconsultation à l'issue du bilan.",
  },
  {
    q: 'Qui est le médecin ?',
    a: "Un médecin généraliste diplômé, inscrit à l'Ordre des Médecins, avec un RPPS vérifiable, formé à une approche globale de la peau. Pour les cas qui le nécessitent, il s'appuie sur notre comité de dermatologues. Vous le rencontrez en téléconsultation, et c'est lui qui assure ensuite votre suivi mensuel si vous continuez.",
  },
  {
    q: 'Comment fonctionne la consultation médicale ?',
    a: "C'est une consultation augmentée. Votre médecin arrive avec tout votre dossier déjà en main : il ne perd pas 15 minutes à le reconstituer. Formé à une approche globale, il s'appuie sur notre comité de dermatologues pour les cas qui le nécessitent, et vous suit dans la durée. Résultat : une consultation dense, préparée, dédiée à votre plan de traitement, là où le parcours classique impose des mois d'attente pour 15 minutes.",
  },
  {
    q: 'Mes données et mes photos sont-elles protégées ?',
    a: "Oui. Vos données (vos photos comprises) sont hébergées sur des serveurs certifiés HDS (Hébergeur de Données de Santé) en France, et soumises au secret médical. Vos photos ne sont jamais transmises à l'IA ni à aucun tiers : elles restent dans votre dossier sécurisé, et seul le médecin que vous consultez peut les ouvrir, uniquement une fois votre rendez-vous réservé, jamais avant.",
  },
  {
    q: "Suis-je obligé·e de prendre un abonnement ?",
    a: "Non. La première téléconsultation se suffit à elle-même : vous repartez avec votre plan de traitement, c'est à vous, vous pouvez vous arrêter là. Le suivi dans la durée est entièrement optionnel, sans engagement, et résiliable à tout moment.",
  },
  {
    q: "En quoi consiste le suivi mensuel ?",
    a: "Deux niveaux d'accompagnement. Au quotidien, l'IA suit votre peau, tient votre journal et répond à vos questions pratiques. Et chaque mois, votre médecin fait le point avec vous, puis renouvelle ou ajuste votre traitement si besoin. C'est un acte médical, réalisé par le médecin, pas par l'IA.",
  },
  {
    q: "Aurai-je forcément une ordonnance ?",
    a: "La prescription relève de la seule décision du médecin. Selon votre cas, il peut prescrire une formule magistrale sur mesure, un traitement dermatologique classique (rétinoïdes, acide azélaïque…), ou recommander une approche essentiellement cosmétique. Dans tous les cas, vous repartez avec un avis médical personnalisé et un plan clair pour votre peau.",
  },
];
---

<section class="px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-24 bg-base">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] text-center mb-12 md:mb-16 text-ink">
        Questions <span class="italic-serif whitespace-nowrap">fréquentes.</span>
      </h2>
    </FadeInSection>

    <div class="max-w-[760px] mx-auto">
      <Accordion client:load items={faq} />
    </div>

    <FadeInSection client:load>
      <div class="max-w-[760px] mx-auto mt-12 md:mt-14 text-center">
        <p class="text-[18px] md:text-[20px] font-medium text-ink mb-5">
          Encore des questions ?
        </p>
        <Button href="/premieres-patientes/" variant="dark">Nous parler 20 min →</Button>
        <p class="mt-4 text-[13px] text-ink-3">
          Ou créez votre dossier dermato, gratuit et sans engagement.
        </p>
      </div>
    </FadeInSection>
  </div>
</section>

<section class="relative overflow-hidden px-6 md:px-10 py-24 md:py-32 bg-deep text-white text-center">
  <div class="relative z-[2] max-w-[780px] mx-auto">
    <FadeInSection client:load>
      <h2 class="text-[36px] md:text-[46px] font-medium leading-[1.12] tracking-[-0.035em] text-white mb-10 max-w-[780px] mx-auto">
        Votre peau mérite mieux<br class="hidden md:inline" /> <span class="italic-serif md:whitespace-nowrap">qu'une ordonnance sans suivi.</span>
      </h2>
      <Button href="/premieres-patientes/" variant="white">Créer mon dossier dermato →</Button>
      <div class="mt-5 text-[13px] text-white/60">
        Gratuit · sans engagement. Vous ne payez que si vous réservez votre téléconsultation.
      </div>
    </FadeInSection>
  </div>
</section>
