---
import PillarCard from '../motion/PillarCard.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';

const pillars = [
  {
    image: '/images/lab-manipulation-vertical.jpg',
    alt: 'Préparation magistrale en pharmacie',
    tag: 'Votre consultation',
    title: 'Une formule sur mesure',
    description: 'Si votre cas le justifie, votre médecin prescrit une formule magistrale qui traite votre problème principal et vos objectifs secondaires : tolérance, éclat, anti-âge.',
    overlay: {
      kind: 'formula' as const,
      patientLabel: 'Composition type',
      rows: [
        { name: 'Acide tranexamique', dose: 'Dépigmentant' },
        { name: 'Acide azélaïque', dose: 'Anti-inflammatoire' },
        { name: 'Rétinoïde', dose: 'Kératolytique' },
      ],
      footer: 'Actifs et dosages choisis par votre médecin, préparés en pharmacie sur ordonnance.',
    },
  },
  {
    image: '/images/closeup-eyebrow.jpg',
    alt: 'Macro peau',
    tag: 'Votre consultation',
    title: 'Un plan construit par étapes',
    description: "Votre médecin ne traite pas qu'un symptôme. Appuyé par notre comité de dermatologues, il construit un plan progressif : on attaque, on stabilise, puis on entretient les résultats, en ajustant à chaque étape.",
    overlay: {
      kind: 'score' as const,
      label: 'Plan de traitement',
      rows: [
        { label: 'Attaque', value: 'Mois 1-2' },
        { label: 'Stabilisation', value: 'Mois 3-4' },
        { label: 'Entretien', value: 'Mois 5-6' },
      ],
      footer: 'Un plan progressif, ajusté par votre médecin à chaque étape.',
    },
  },
  {
    image: '/images/pillar-suivi-dermato.jpg',
    alt: 'Patiente lisant un message de son médecin depuis son canapé',
    tag: 'Si vous continuez · sans engagement',
    title: 'Un suivi médical, dans la durée',
    description: "Au quotidien, l'IA suit votre peau et répond à vos questions. Chaque mois, votre médecin fait le point, renouvelle ou ajuste votre traitement si besoin.",
    overlay: {
      kind: 'chat' as const,
      doctor: 'Dr Estelle G.',
      status: 'En ligne',
      message: "Belle progression. Je renouvelle votre formule et ajuste le dosage.",
      reply: 'Voir mon traitement →',
      avatar: '/images/estelle-grimonet.jpg',
    },
  },
];
---

<section id="approche" class="px-6 md:px-10 py-24 md:py-32 bg-cream">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-warm mb-5">
        <span class="inline-block h-px w-10 bg-warm/80"></span>
        Notre approche
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] max-w-[760px] mb-5 text-ink">
        On vous accompagne<br class="hidden md:inline" /> <span class="italic-serif whitespace-nowrap">du début à la fin.</span>
      </h2>
      <p class="text-[17px] md:text-lg leading-relaxed text-ink-2 max-w-[580px]">
        De votre bilan à un traitement qui fonctionne, puis qui s'ajuste dans la durée grâce à un suivi médical régulier. Votre médecin reste à vos côtés bien après l'ordonnance, sans jamais vous laisser seul·e.
      </p>
    </FadeInSection>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7 mt-14 md:mt-16">
      {pillars.map((p, i) => (
        <PillarCard
          client:load
          image={p.image}
          alt={p.alt}
          tag={p.tag}
          title={p.title}
          description={p.description}
          overlay={p.overlay}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
