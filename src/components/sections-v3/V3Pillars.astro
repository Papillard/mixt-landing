---
import PillarCard from '../motion/PillarCard.tsx';
import FadeInSection from '../motion/FadeInSection.tsx';

const pillars = [
  {
    image: '/images/lab-manipulation-vertical.jpg',
    alt: 'Préparation magistrale en pharmacie',
    title: 'Une formule sur mesure',
    description: 'Si votre cas le justifie, votre dermatologue prescrit une formule magistrale qui traite votre problème principal et vos objectifs secondaires : tolérance, éclat, anti-âge.',
    overlay: {
      kind: 'formula' as const,
      patientLabel: 'Composition type',
      rows: [
        { name: 'Dépigmentant', dose: '' },
        { name: 'Anti-inflammatoire', dose: '' },
        { name: 'Kératolytique', dose: '' },
      ],
      footer: 'Préparée en pharmacie partenaire selon prescription.',
    },
  },
  {
    image: '/images/closeup-eyebrow.jpg',
    alt: 'Macro peau',
    title: 'Une approche globale',
    description: "Votre dermatologue ne traite pas qu'un symptôme. Il combine prescription, routine et conseils adaptés à votre peau, vos sensibilités, vos objectifs.",
    overlay: {
      kind: 'score' as const,
      label: 'Plan personnalisé',
      rows: [
        { label: 'Traitement principal', value: '●●●●●' },
        { label: 'Tolérance', value: '●●●○○' },
        { label: 'Vos objectifs', value: '●●●●○' },
        { label: 'Routine quotidienne', value: '●●●●●' },
      ],
      footer: 'Adapté à votre profil par votre dermatologue.',
    },
  },
  {
    image: '/images/pillar-suivi-dermato.jpg',
    alt: 'Patiente lisant un message de sa dermatologue depuis son canapé',
    title: 'Un accompagnement humain',
    description: "Photos, questions, conseils. On vous suit chaque semaine et on fait le lien avec votre dermatologue.",
    overlay: {
      kind: 'chat' as const,
      doctor: 'Laetitia · Équipe Mixt',
      status: 'Bilan M3',
      message: "Vos photos montrent une belle évolution. On prépare avec vous votre prochaine consultation pour ajuster si besoin.",
      reply: 'Voir mon bilan',
      avatar: '/images/laetitia-after.webp',
    },
  },
];
---

<section id="approche" class="px-6 md:px-10 py-24 md:py-32 bg-cream">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-warm mb-5">
        <span class="inline-block h-px w-10 bg-warm/80"></span>
        Notre approche
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] max-w-[760px] mb-5 text-ink">
        On vous accompagne<br class="hidden md:inline" /> <span class="italic-serif whitespace-nowrap">du début à la fin.</span>
      </h2>
      <p class="text-[17px] md:text-lg leading-relaxed text-ink-2 max-w-[580px]">
        Un parcours dermatologique structuré, du premier dossier au suivi dans la durée. Sans jamais être seul·e.
      </p>
    </FadeInSection>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7 mt-14 md:mt-16">
      {pillars.map((p, i) => (
        <PillarCard
          client:load
          image={p.image}
          alt={p.alt}
          title={p.title}
          description={p.description}
          overlay={p.overlay}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
