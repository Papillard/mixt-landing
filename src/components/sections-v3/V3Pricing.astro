---
import Button from '../Button.astro';
import FadeInSection from '../motion/FadeInSection.tsx';

const ledger = [
  {
    label: 'Bilan dermato',
    price: 'Gratuit',
    who: 'Mixt · gratuit',
    get: 'Dossier structuré avec assistant IA',
  },
  {
    label: 'Téléconsultation',
    price: '59 €',
    who: 'Reversés intégralement au médecin',
    get: 'Consultation dense, plan personnalisé, ordonnance si besoin',
    highlight: true,
  },
  {
    label: "Suivi avec l'assistant IA Mixt",
    price: 'Inclus',
    who: 'Au quotidien, avec votre plan',
    get: "Questions pratiques sur le plan de traitement, journaling photo toutes les deux semaines, conseils cosméto. Pas de diagnostic ni d'avis médical.",
  },
  {
    label: 'Suivi par le médecin',
    price: '29 €/mois',
    who: 'Optionnel, sans engagement, résiliable',
    get: "Point mensuel sur 3 à 6 mois pour adapter ou renouveler le plan de traitement et l'ordonnance si besoin.",
  },
  {
    label: 'Préparation pharmacie',
    price: '30-60 €',
    who: 'Si prescrite · remboursement partiel',
    get: 'Formule magistrale sur mesure',
  },
];

const compareRows = [
  { label: 'Accès à un médecin', classic: "3 à 6 mois d'attente", mixt: 'Téléconsultation sous quelques jours' },
  { label: 'Préparation de la consultation', classic: 'À votre charge', mixt: 'Bilan IA + dossier structuré, en amont' },
  { label: 'Ce que reçoit le médecin', classic: 'Ce que vous racontez en 15 min', mixt: 'Historique complet, photos, traitements essayés' },
  { label: 'Entre les rendez-vous', classic: 'Aucun accompagnement', mixt: 'Suivi IA quotidien + médecin chaque mois' },
  { label: "Suivi de l'évolution", classic: 'Évaluation au RDV suivant', mixt: 'Photos mensuelles et journal de peau' },
  { label: 'À 3 mois', classic: 'Nouveau RDV à votre initiative', mixt: "Bilan d'évolution, traitement déjà ajusté en continu" },
];

// TODO: obtenir les accords formels et photos N&B des trois professeurs
const advisors = [
  { name: 'Pr Brigitte Dreno', affiliation: 'CHU Nantes · Dermatologie', initials: 'BD' },
  { name: 'Pr Selim Aractingi', affiliation: 'Hôpital Saint-Louis · Dermatologie', initials: 'SA' },
  { name: 'Pr Alain Taïeb', affiliation: 'CHU Bordeaux · Dermatologie', initials: 'AT' },
];

const logos = ['CHU Nantes', 'Hôpital Saint-Louis', 'SFD', 'HDS'];
---

<section id="tarifs" class="px-6 md:px-10 py-24 md:py-32 bg-base">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] text-center max-w-[880px] mx-auto mb-4 text-ink">
        Ce que vous payez, <span class="italic-serif whitespace-nowrap">et à qui.</span>
      </h2>
      <p class="text-center text-[15px] md:text-[16px] text-ink-2 max-w-[620px] mx-auto leading-relaxed">
        La transparence, dès le premier jour. Vous savez exactement où va chaque euro.
      </p>
    </FadeInSection>

    <FadeInSection client:load delay={0.1}>
      <div class="max-w-[860px] mx-auto mt-14 overflow-hidden rounded-[12px] border border-black/[0.08] bg-base">
        {ledger.map((row, i) => (
          <div class={`flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 px-5 md:px-7 py-5 ${i < ledger.length - 1 ? 'border-b border-black/[0.07]' : ''} ${row.highlight ? 'bg-cream/60' : ''}`}>
            <div class="sm:w-[230px] shrink-0">
              <div class="text-[15px] font-semibold text-ink">{row.label}</div>
              <div class="text-[12px] text-ink-3 mt-0.5">{row.who}</div>
            </div>
            <div class="flex-1 text-[13.5px] text-ink-2 leading-snug order-3 sm:order-2">{row.get}</div>
            <div class={`order-2 sm:order-3 sm:text-right font-semibold tracking-[-0.02em] ${row.highlight ? 'text-[28px] text-ink' : 'text-[20px] text-ink'}`}>{row.price}</div>
          </div>
        ))}
      </div>
    </FadeInSection>

    <FadeInSection client:load delay={0.15}>
      <div class="max-w-[860px] mx-auto mt-6 rounded-[12px] bg-sage-light/30 border border-sage-deep/15 px-6 md:px-8 py-6">
        <p class="text-[15px] md:text-[16px] leading-[1.6] text-ink">
          <strong class="font-semibold">Les 59 € reviennent intégralement au médecin.</strong> Mixt ne prélève aucun frais sur la consultation. Vous repartez avec un plan de traitement personnalisé et, le cas échéant, l'ordonnance de votre formule magistrale sur mesure. C'est à vous, vous êtes libre de vous arrêter là. Si vous voulez continuer, le suivi est sans engagement.
        </p>
        <p class="mt-3 text-[11px] text-ink-3 leading-snug">
          Toute prescription relève de la seule appréciation du médecin.
        </p>
      </div>
    </FadeInSection>

    <FadeInSection client:load delay={0.2}>
      <div class="flex flex-col items-center gap-3 mt-12 mb-2">
        <Button href="/premieres-patientes/" variant="dark">Créer mon dossier dermato →</Button>
        <p class="font-mono text-[11px] text-ink-3 tracking-[0.04em]">Gratuit · vous ne payez que si vous réservez votre téléconsultation</p>
      </div>
    </FadeInSection>

    {/*
      Advisory strip (Pr Dreno / Pr Aractingi / Pr Taïeb + logos CHU / SFD / HDS)
      masquée tant qu'on n'a pas le board médical formel et les accords.
      À ré-activer quand les partenariats sont signés.

      <FadeInSection client:load>
        <div class="mt-24 md:mt-28 pt-14 border-t border-black/[0.08] text-center">
          <h4 class="text-[11px] uppercase tracking-[0.18em] text-ink-2 font-semibold mb-10">
            Protocole validé par un comité scientifique
          </h4>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-[720px] mx-auto mb-12">
            {advisors.map((a) => (
              <div class="flex flex-col items-center gap-3">
                <div class="w-24 h-24 rounded-full bg-cream border border-black/[0.08] flex items-center justify-center">
                  <span class="font-semibold text-[20px] text-ink-2 tracking-[0.04em]">{a.initials}</span>
                </div>
                <strong class="text-[14px] font-semibold text-ink">{a.name}</strong>
                <span class="text-[11.5px] text-ink-3">{a.affiliation}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap justify-center gap-5 md:gap-8 pt-8 border-t border-black/[0.08]">
            {logos.map((l) => (
              <div class="px-4 py-3 rounded-[6px] border border-black/[0.08] text-[11px] text-ink-3 uppercase tracking-[0.12em]">
                {l}
              </div>
            ))}
          </div>
        </div>
      </FadeInSection>
    */}
  </div>
</section>

<section class="px-6 md:px-10 py-24 md:py-32 bg-sage-light/25">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center justify-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-sage-deep mb-5">
        <span class="inline-block h-px w-10 bg-sage-deep/70"></span>
        La différence concrète
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] text-center max-w-[760px] mx-auto mb-4 text-ink">
        Avec Mixt, <span class="italic-serif">concrètement.</span>
      </h2>
      <p class="text-center text-[15px] md:text-[16px] text-ink-2 max-w-[640px] mx-auto leading-relaxed mb-14 md:mb-16">
        Voici ce que Mixt apporte en plus du parcours dermatologique classique.
      </p>
    </FadeInSection>

    <FadeInSection client:load delay={0.1}>
      <div class="hidden md:block max-w-[920px] mx-auto overflow-hidden rounded-[12px] border border-black/[0.08] bg-base">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink-3 font-semibold bg-cream/60 border-b border-black/[0.08]">&nbsp;</th>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink-3 font-semibold bg-cream/60 border-b border-black/[0.08]">Parcours classique</th>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink font-semibold bg-cream border-b border-black/[0.08] border-l border-r border-warm/40">Avec Mixt</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((r, i) => (
              <tr class={i < compareRows.length - 1 ? 'border-b border-black/[0.06]' : ''}>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink font-medium">{r.label}</td>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink-2">{r.classic}</td>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink bg-cream/60 border-l border-r border-warm/40 font-medium">{r.mixt}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </FadeInSection>

    <FadeInSection client:load delay={0.18}>
      <div class="flex flex-wrap justify-center gap-x-7 gap-y-3 mt-12 md:mt-14 text-[12.5px] text-ink-2">
        <span>✓ Secret médical respecté</span>
        <span>✓ Données de santé hébergées en France (HDS)</span>
        <span>✓ Médecin diplômé, RPPS vérifiable</span>
      </div>
    </FadeInSection>
  </div>
</section>
