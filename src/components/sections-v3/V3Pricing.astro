---
import Button from '../Button.astro';
import FadeInSection from '../motion/FadeInSection.tsx';

const features = [
  'Un dermatologue qui valide, ajuste et renouvelle votre traitement en continu',
  'Votre experte Mixt chaque semaine : photos, questions, routine',
  'Un accès dermatologue sous une semaine — jamais 6 mois d\'attente',
  'Des renouvellements et ajustements aussi souvent que votre peau en a besoin',
  'Données hébergées en France (HDS), secret médical',
];

const compareRows = [
  { label: 'Accès au dermatologue', classic: "3 à 6 mois d'attente", mixt: 'Sous 1 semaine, via le réseau partenaire' },
  { label: 'Suivi entre les consultations', classic: 'Aucun accompagnement', mixt: 'Votre experte Mixt chaque semaine' },
  { label: 'Ajustement du traitement', classic: 'Au prochain RDV, si vous le reprenez', mixt: 'Ajusté en continu par votre dermatologue' },
  { label: 'Renouvellement', classic: 'À votre initiative, nouvelle ordonnance', mixt: 'Calé sur votre cycle de traitement' },
  { label: "Suivi de l'évolution", classic: 'Évaluation visuelle au RDV suivant', mixt: 'Photos régulières et journal de votre peau' },
  { label: 'Face à un doute', classic: 'Seule, jusqu\'au prochain rendez-vous', mixt: 'Votre experte répond, le derm intervient si besoin' },
];

// TODO: obtenir les accords formels et photos N&B des trois professeurs
const advisors = [
  { name: 'Pr Brigitte Dreno', affiliation: 'CHU Nantes · Dermatologie', initials: 'BD' },
  { name: 'Pr Selim Aractingi', affiliation: 'Hôpital Saint-Louis · Dermatologie', initials: 'SA' },
  { name: 'Pr Alain Taïeb', affiliation: 'CHU Bordeaux · Dermatologie', initials: 'AT' },
];

const logos = ['CHU Nantes', 'Hôpital Saint-Louis', 'SFD', 'HDS'];
---

<section id="tarifs" class="px-6 md:px-10 py-24 md:py-32 bg-base">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] text-center max-w-[880px] mx-auto mb-4 text-ink">
        Un suivi transparent, <span class="italic-serif whitespace-nowrap">pensé pour durer.</span>
      </h2>
      <p class="text-center text-[15px] md:text-[16px] text-ink-2 max-w-[640px] mx-auto leading-relaxed">
        Un seul prix Mixt : 29 €/mois pour votre suivi médical continu. Le traitement, lui, est à part — prescrit par votre dermatologue, préparé en pharmacie, et en partie remboursé.
      </p>
    </FadeInSection>

    <FadeInSection client:load delay={0.1}>
      <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-5 md:gap-8 max-w-[1080px] mx-auto mt-14 mb-14 items-stretch">
        {/* Colonne gauche · offre Mixt */}
        <div class="relative p-10 md:p-12 bg-deep text-white rounded-[12px] shadow-[0_30px_80px_-30px_rgba(54,24,34,0.6)] flex flex-col">
          <div class="inline-flex self-start items-center gap-2 mb-5 rounded-full bg-ember text-deep px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em]">
            <span class="inline-block w-[5px] h-[5px] rounded-full bg-deep"></span>
            Offre lancement · 100 places
          </div>
          <div class="flex items-baseline gap-2 mb-2">
            <div class="text-[68px] md:text-[80px] font-semibold leading-none tracking-[-0.04em]">
              29 €
            </div>
            <div class="text-[20px] md:text-[24px] font-medium leading-none text-white/55">
              /mois
            </div>
          </div>
          <div class="text-[14px] text-white/60 mb-7 pb-6 border-b border-white/15">
            Votre suivi médical continu · engagement 2 mois, calé sur votre cycle de traitement.
          </div>
          <ul class="flex flex-col gap-1 mb-7">
            {features.map((f) => (
              <li class="flex items-start gap-3 text-[14px] text-white/90 py-1">
                <span class="text-jade">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="mt-auto">
            <Button href="/premieres-patientes" variant="white" class="w-full justify-center">Commencer mon suivi →</Button>
          </div>
        </div>

        {/* Colonne droite · le traitement, à part (texte libre) */}
        <div class="px-2 md:px-6 py-6 md:py-10 flex flex-col justify-center">
          <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-3 font-semibold mb-8">
            Le traitement, à part
          </div>
          <div class="flex flex-col gap-7">
            <div>
              <div class="text-[17px] font-semibold text-ink mb-2">Votre formule magistrale sur mesure</div>
              <p class="text-[14px] leading-[1.6] text-ink-2">
                Si votre dermatologue la prescrit, elle est préparée en pharmacie partenaire : comptez 30 à 60 € selon les actifs. C'est votre traitement, il vous appartient — il n'est pas inclus dans l'abonnement.
              </p>
            </div>
            <div class="pt-6 border-t border-black/[0.1]">
              <div class="text-[17px] font-semibold text-ink mb-2">En partie remboursée</div>
              <p class="text-[14px] leading-[1.6] text-ink-2">
                Parce que c'est une vraie prescription médicale, votre formule est partiellement remboursée par la Sécurité sociale et votre mutuelle — là où la plupart des services en ligne vous laissent tout à votre charge.
              </p>
            </div>
          </div>
        </div>
      </div>
    </FadeInSection>

    {/*
      Advisory strip (Pr Dreno / Pr Aractingi / Pr Taïeb + logos CHU / SFD / HDS)
      masquée tant qu'on n'a pas le board médical formel et les accords.
      À ré-activer quand les partenariats sont signés.

      <FadeInSection client:load>
        <div class="mt-24 md:mt-28 pt-14 border-t border-black/[0.08] text-center">
          <h4 class="text-[11px] uppercase tracking-[0.18em] text-ink-2 font-semibold mb-10">
            Protocole validé par un comité scientifique
          </h4>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-[720px] mx-auto mb-12">
            {advisors.map((a) => (
              <div class="flex flex-col items-center gap-3">
                <div class="w-24 h-24 rounded-full bg-cream border border-black/[0.08] flex items-center justify-center">
                  <span class="font-semibold text-[20px] text-ink-2 tracking-[0.04em]">{a.initials}</span>
                </div>
                <strong class="text-[14px] font-semibold text-ink">{a.name}</strong>
                <span class="text-[11.5px] text-ink-3">{a.affiliation}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap justify-center gap-5 md:gap-8 pt-8 border-t border-black/[0.08]">
            {logos.map((l) => (
              <div class="px-4 py-3 rounded-[6px] border border-black/[0.08] text-[11px] text-ink-3 uppercase tracking-[0.12em]">
                {l}
              </div>
            ))}
          </div>
        </div>
      </FadeInSection>
    */}
  </div>
</section>

<section class="px-6 md:px-10 py-24 md:py-32 bg-sage-light/25">
  <div class="max-w-[1200px] mx-auto">
    <FadeInSection client:load>
      <div class="flex items-center justify-center gap-3 font-mono text-[11px] uppercase tracking-[0.18em] text-sage-deep mb-5">
        <span class="inline-block h-px w-10 bg-sage-deep/70"></span>
        La différence concrète
      </div>
      <h2 class="text-[40px] md:text-[52px] font-medium leading-[1.06] tracking-[-0.035em] text-center max-w-[760px] mx-auto mb-4 text-ink">
        Avec Mixt, <span class="italic-serif">concrètement.</span>
      </h2>
      <p class="text-center text-[15px] md:text-[16px] text-ink-2 max-w-[640px] mx-auto leading-relaxed mb-14 md:mb-16">
        Voici ce que Mixt apporte en plus du parcours dermatologique classique.
      </p>
    </FadeInSection>

    <FadeInSection client:load delay={0.1}>
      <div class="hidden md:block max-w-[920px] mx-auto overflow-hidden rounded-[12px] border border-black/[0.08] bg-base">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink-3 font-semibold bg-cream/60 border-b border-black/[0.08]">&nbsp;</th>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink-3 font-semibold bg-cream/60 border-b border-black/[0.08]">Parcours classique</th>
              <th class="text-left px-5 md:px-6 py-4 text-[11px] uppercase tracking-[0.14em] text-ink font-semibold bg-cream border-b border-black/[0.08] border-l border-r border-warm/40">Avec Mixt</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((r, i) => (
              <tr class={i < compareRows.length - 1 ? 'border-b border-black/[0.06]' : ''}>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink font-medium">{r.label}</td>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink-2">{r.classic}</td>
                <td class="px-5 md:px-6 py-4 text-[14px] text-ink bg-cream/60 border-l border-r border-warm/40 font-medium">{r.mixt}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </FadeInSection>

    <FadeInSection client:load delay={0.18}>
      <div class="flex flex-wrap justify-center gap-x-7 gap-y-3 mt-12 md:mt-14 text-[12.5px] text-ink-2">
        <span>✓ Secret médical respecté</span>
        <span>✓ Données de santé hébergées en France (HDS)</span>
        <span>✓ Médecin diplômé, RPPS vérifiable</span>
      </div>
    </FadeInSection>
  </div>
</section>
